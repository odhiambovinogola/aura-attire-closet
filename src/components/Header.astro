---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const navItems = [
  { label: "Home", href: "/" },
  { label: "Shop", href: "/shop" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];
---

<header
  data-transparent={transparent ? "true" : "false"}
  class={`fixed inset-x-0 top-0 z-50 transition-colors duration-300 ${
    transparent ? "border-b border-transparent bg-transparent text-cream" : "border-b border-gold-light/40 bg-cream/95 text-ink backdrop-blur-sm"
  }`}
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="inline-flex flex-col items-start">
      <span class="font-[family-name:var(--font-display)] text-xl font-bold tracking-wide text-logo-gold">
        Aura Attire Closet
      </span>
      <span class="mt-0.5 h-px w-full bg-logo-gold/50"></span>
    </a>

    <nav class="hidden items-center gap-6 sm:flex">
      {navItems.map((item) => (
        <a href={item.href} class="text-sm font-medium tracking-wide hover:text-gold">
          {item.label}
        </a>
      ))}
      <form action="/shop" method="get" class="flex items-center">
        <input
          id="search-input"
          type="search"
          name="q"
          placeholder="Search products"
          class="w-0 rounded-full border border-transparent px-0 py-1.5 text-sm text-ink opacity-0 transition-all duration-200 focus:outline-none"
        />
        <button type="button" id="search-toggle" aria-label="Search" class="flex h-9 w-9 items-center justify-center hover:text-gold">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="11" cy="11" r="7" />
            <path d="M21 21l-4.3-4.3" stroke-linecap="round" />
          </svg>
        </button>
      </form>
      <a href="/wishlist" aria-label="View wishlist" class="relative flex h-9 w-9 items-center justify-center hover:text-gold">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M12 20s-7-4.35-9.5-8.5C.8 8.2 2.4 5 5.6 5c1.8 0 3.2.9 4 2.2C10.4 5.9 11.8 5 13.6 5 16.8 5 18.4 8.2 21.5 11.5 19 15.65 12 20 12 20z" stroke-linejoin="round" />
        </svg>
        <span id="wishlist-count" class="absolute -right-1 -top-1 hidden h-4 min-w-4 items-center justify-center rounded-full bg-gold px-1 text-[10px] font-semibold text-cream">0</span>
      </a>
      <a href="/cart" aria-label="View cart" class="relative flex h-9 w-9 items-center justify-center hover:text-gold">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M3 4h2l2.4 12.4a2 2 0 0 0 2 1.6h7.2a2 2 0 0 0 2-1.6L20 8H6" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="9" cy="21" r="1.2" />
          <circle cx="17" cy="21" r="1.2" />
        </svg>
        <span id="cart-count" class="absolute -right-1 -top-1 hidden h-4 min-w-4 items-center justify-center rounded-full bg-gold px-1 text-[10px] font-semibold text-cream">0</span>
      </a>
    </nav>

    <div class="flex items-center gap-3 sm:hidden">
      <a href="/wishlist" aria-label="View wishlist" class="relative flex h-10 w-10 items-center justify-center">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M12 20s-7-4.35-9.5-8.5C.8 8.2 2.4 5 5.6 5c1.8 0 3.2.9 4 2.2C10.4 5.9 11.8 5 13.6 5 16.8 5 18.4 8.2 21.5 11.5 19 15.65 12 20 12 20z" stroke-linejoin="round" />
        </svg>
        <span id="wishlist-count-mobile" class="absolute -right-1 -top-1 hidden h-4 min-w-4 items-center justify-center rounded-full bg-gold px-1 text-[10px] font-semibold text-cream">0</span>
      </a>
      <a href="/cart" aria-label="View cart" class="relative flex h-10 w-10 items-center justify-center">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M3 4h2l2.4 12.4a2 2 0 0 0 2 1.6h7.2a2 2 0 0 0 2-1.6L20 8H6" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="9" cy="21" r="1.2" />
          <circle cx="17" cy="21" r="1.2" />
        </svg>
        <span id="cart-count-mobile" class="absolute -right-1 -top-1 hidden h-4 min-w-4 items-center justify-center rounded-full bg-gold px-1 text-[10px] font-semibold text-cream">0</span>
      </a>

      <button
        id="nav-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        class="flex h-10 w-10 items-center justify-center"
      >
        <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="hidden flex-col gap-1 border-t border-gold-light/40 bg-cream px-4 py-2 text-ink sm:hidden">
    <form action="/shop" method="get" class="py-2">
      <input
        type="search"
        name="q"
        placeholder="Search products"
        class="w-full rounded-full border border-gold-light/60 px-3 py-2 text-sm"
      />
    </form>
    {navItems.map((item) => (
      <a href={item.href} class="py-2 text-sm font-medium tracking-wide hover:text-gold">
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  import { cartItems, cartCount } from "../lib/cart";
  import { wishlistItems } from "../lib/wishlist";

  const header = document.querySelector<HTMLElement>("header[data-transparent]");
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-nav");
  const isTransparent = header?.dataset.transparent === "true";

  const solidClasses = ["bg-cream/95", "text-ink", "backdrop-blur-sm", "border-gold-light/40"];
  const transparentClasses = ["bg-transparent", "text-cream", "border-transparent"];

  function applySolid(solid: boolean) {
    header!.classList.remove(...solidClasses, ...transparentClasses);
    header!.classList.add(...(solid ? solidClasses : transparentClasses));
  }

  function syncHeader() {
    const menuOpen = menu?.classList.contains("flex");
    applySolid(menuOpen || window.scrollY > 40);
  }

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("flex");
    menu?.classList.toggle("hidden", isOpen);
    menu?.classList.toggle("flex", !isOpen);
    toggle.setAttribute("aria-expanded", String(!isOpen));
    if (isTransparent) syncHeader();
  });

  if (isTransparent) {
    syncHeader();
    window.addEventListener("scroll", syncHeader, { passive: true });
  }

  function renderCartBadge(count: number) {
    for (const id of ["cart-count", "cart-count-mobile"]) {
      const el = document.getElementById(id);
      if (!el) continue;
      el.textContent = String(count);
      el.classList.toggle("hidden", count === 0);
      el.classList.toggle("flex", count > 0);
    }
  }

  cartItems.subscribe((items) => renderCartBadge(cartCount(items)));

  function renderWishlistBadge(count: number) {
    for (const id of ["wishlist-count", "wishlist-count-mobile"]) {
      const el = document.getElementById(id);
      if (!el) continue;
      el.textContent = String(count);
      el.classList.toggle("hidden", count === 0);
      el.classList.toggle("flex", count > 0);
    }
  }

  wishlistItems.subscribe((items) => renderWishlistBadge(items.length));

  const searchToggle = document.getElementById("search-toggle");
  const searchInput = document.getElementById("search-input");
  const collapsedClasses = ["w-0", "px-0", "opacity-0", "border-transparent"];
  const expandedClasses = ["w-40", "px-3", "opacity-100", "border-gold-light/60"];

  searchToggle?.addEventListener("click", () => {
    const isOpen = searchInput?.classList.contains("w-40");
    searchInput?.classList.remove(...(isOpen ? expandedClasses : collapsedClasses));
    searchInput?.classList.add(...(isOpen ? collapsedClasses : expandedClasses));
    if (!isOpen) (searchInput as HTMLInputElement | null)?.focus();
  });
</script>
