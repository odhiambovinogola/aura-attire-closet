---
import type { Product } from "../lib/types";
import { formatKES } from "../lib/format";
import { colourToHex } from "../lib/colours";
import { productImageUrl } from "../lib/images";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const primaryImage = product.product_images?.find((img) => img.is_primary) ?? product.product_images?.[0];
---

<a href={`/product/${product.slug}`} class="product-card group block">
  <div class="product-card-media relative aspect-[3/4] overflow-hidden rounded-sm bg-blush">
    {primaryImage ? (
      <img
        src={productImageUrl(primaryImage.storage_path)}
        alt={primaryImage.alt ?? product.name}
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center px-3 text-center text-sm text-taupe">
        {product.name}
      </div>
    )}
    <button
      type="button"
      class="wishlist-toggle absolute right-2 top-2 flex h-8 w-8 items-center justify-center rounded-full bg-cream/90 text-ink shadow hover:bg-cream"
      data-wishlist-slug={product.slug}
      data-wishlist-name={product.name}
      data-wishlist-price={product.price_kes}
      data-wishlist-image={primaryImage?.storage_path ?? ""}
      aria-label="Toggle wishlist"
    >
      <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
        <path
          d="M12 20s-7-4.35-9.5-8.5C.8 8.2 2.4 5 5.6 5c1.8 0 3.2.9 4 2.2C10.4 5.9 11.8 5 13.6 5 16.8 5 18.4 8.2 21.5 11.5 19 15.65 12 20 12 20z"
          stroke-linejoin="round"
        />
      </svg>
    </button>
    <button
      type="button"
      class="quick-add absolute right-2 top-12 flex h-8 w-8 items-center justify-center rounded-full bg-cream/90 text-ink shadow hover:bg-cream"
      data-quick-add-slug={product.slug}
      data-quick-add-name={product.name}
      data-quick-add-price={product.price_kes}
      data-quick-add-colour={product.colours[0] ?? "Any"}
      aria-label="Add to bag"
    >
      <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M6 7h12l1 13H5L6 7Z" stroke-linejoin="round" stroke-linecap="round" />
        <path d="M9 7V6a3 3 0 0 1 6 0v1" stroke-linecap="round" />
        <path d="M12 11v4M10 13h4" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <h3 class="mt-3 text-sm font-medium text-ink transition-colors group-hover:text-gold">{product.name}</h3>
  <p class="mt-1 text-sm font-semibold text-gold">{formatKES(product.price_kes)}</p>

  {product.colours.length > 0 && (
    <div class="mt-2 flex gap-1.5">
      {product.colours.slice(0, 5).map((colour) => (
        <span
          class="h-3.5 w-3.5 shrink-0 rounded-full border border-gold-light"
          style={`background-color: ${colourToHex(colour)}`}
          title={colour}
        />
      ))}
    </div>
  )}
</a>

<script>
  import { wishlistItems, toggleWishlist } from "../lib/wishlist";
  import { addToCart } from "../lib/cart";
  import { showToast } from "../lib/toast";

  function syncButtons() {
    const slugs = new Set(wishlistItems.get().map((item) => item.productSlug));
    document.querySelectorAll<HTMLButtonElement>(".wishlist-toggle").forEach((button) => {
      const isActive = slugs.has(button.dataset.wishlistSlug ?? "");
      button.classList.toggle("text-gold", isActive);
      button.querySelector("svg")?.setAttribute("fill", isActive ? "currentColor" : "none");
    });
  }

  document.querySelectorAll<HTMLButtonElement>(".wishlist-toggle").forEach((button) => {
    button.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      toggleWishlist({
        productSlug: button.dataset.wishlistSlug ?? "",
        name: button.dataset.wishlistName ?? "",
        priceKes: Number(button.dataset.wishlistPrice ?? 0),
        imagePath: button.dataset.wishlistImage || undefined,
      });
    });
  });

  wishlistItems.subscribe(syncButtons);

  document.querySelectorAll<HTMLButtonElement>(".quick-add").forEach((button) => {
    button.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      const name = button.dataset.quickAddName ?? "";
      addToCart({
        productSlug: button.dataset.quickAddSlug ?? "",
        name,
        colour: button.dataset.quickAddColour ?? "Any",
        quantity: 1,
        priceKes: Number(button.dataset.quickAddPrice ?? 0),
      });
      showToast(`${name} added to your bag!`);
    });
  });
</script>
