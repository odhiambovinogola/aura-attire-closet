---
import type { Product } from "../lib/types";
import { formatKES } from "../lib/format";
import { colourToHex } from "../lib/colours";
import { productImageUrl } from "../lib/images";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const primaryImage = product.product_images?.find((img) => img.is_primary) ?? product.product_images?.[0];
---

<a href={`/product/${product.slug}`} class="group block">
  <div class="aspect-[3/4] overflow-hidden rounded-lg bg-ink/5">
    {primaryImage ? (
      <img
        src={productImageUrl(primaryImage.storage_path)}
        alt={primaryImage.alt ?? product.name}
        loading="lazy"
        class="h-full w-full object-cover transition-transform group-hover:scale-105"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-sm text-ink/40">
        {product.name}
      </div>
    )}
  </div>

  <h3 class="mt-3 text-sm font-medium">{product.name}</h3>
  <p class="mt-1 text-sm text-ink/70">{formatKES(product.price_kes)}</p>

  {product.colours.length > 0 && (
    <div class="mt-2 flex gap-1.5">
      {product.colours.slice(0, 5).map((colour) => (
        <span
          class="h-3.5 w-3.5 rounded-full border border-ink/15"
          style={`background-color: ${colourToHex(colour)}`}
          title={colour}
        />
      ))}
    </div>
  )}
</a>
