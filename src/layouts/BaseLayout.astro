---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  transparentHeader?: boolean;
}

const {
  title,
  description = "Aura Attire Closet — boutique dresses, sets, jumpsuits, bags and shoes by Nash Mbula.",
  transparentHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-aura.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,500&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Aura Attire Closet</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | Aura Attire Closet`} />
    <meta property="og:description" content={description} />
  </head>
  <body class="flex min-h-screen flex-col font-sans">
    <Header transparent={transparentHeader} />
    <main class={`flex-1 ${transparentHeader ? "" : "pt-16"}`}>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
