---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Bag" description="Review your order and send it to Nash on WhatsApp.">
  <div class="mx-auto max-w-2xl px-4 py-8 sm:px-6">
    <div class="relative inline-block">
      <div class="absolute -left-4 -top-3 -z-10 h-12 w-12 rounded-full bg-gold-light/50"></div>
      <h1 class="font-[family-name:var(--font-display)] text-3xl font-bold text-ink">Your Order</h1>
    </div>

    <ol class="mt-6 flex items-center">
      <li data-step-label="review" class="step-item flex items-center gap-2 text-sm font-medium text-taupe">
        <span data-step-circle class="step-circle flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-semibold transition-colors">1</span>
        <span class="hidden sm:inline">Review</span>
      </li>
      <span data-step-line class="step-line mx-2 h-px flex-1 bg-gold-light transition-colors sm:mx-3"></span>
      <li data-step-label="delivery" class="step-item flex items-center gap-2 text-sm font-medium text-taupe">
        <span data-step-circle class="step-circle flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-semibold transition-colors">2</span>
        <span class="hidden sm:inline">Delivery</span>
      </li>
      <span data-step-line class="step-line mx-2 h-px flex-1 bg-gold-light transition-colors sm:mx-3"></span>
      <li data-step-label="confirm" class="step-item flex items-center gap-2 text-sm font-medium text-taupe">
        <span data-step-circle class="step-circle flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-semibold transition-colors">3</span>
        <span class="hidden sm:inline">Confirm</span>
      </li>
    </ol>

    <div id="cart-empty" class="mt-10 hidden rounded-lg bg-blush px-4 py-10 text-center text-sm text-taupe">
      Your cart is empty. <a href="/shop" class="font-medium text-gold underline">Browse the shop</a>.
    </div>

    <!-- Step 1: Review -->
    <section id="step-review" class="mt-8 hidden">
      <ul id="cart-lines" class="divide-y divide-gold-light/40 rounded-lg border border-gold-light px-4"></ul>
      <p class="mt-4 flex justify-between rounded-lg bg-blush px-4 py-3 text-base font-semibold">
        <span>Total</span>
        <span id="cart-total"></span>
      </p>
      <button
        type="button"
        id="to-delivery"
        class="mt-6 w-full rounded-sm bg-gold px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-gold-dark"
      >
        Continue to delivery
      </button>
    </section>

    <!-- Step 2: Delivery -->
    <section id="step-delivery" class="mt-8 hidden">
      <p class="text-sm font-medium">Choose a delivery option</p>
      <div id="delivery-options" class="mt-3 space-y-2">
        <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-gold-light p-4 has-[:checked]:border-gold has-[:checked]:bg-blush">
          <input type="radio" name="delivery" value="Pickup Mtaani" class="mt-0.5 accent-gold" />
          <span>
            <span class="block text-sm font-medium">Pickup Mtaani</span>
            <span class="block text-sm text-taupe">Collect from a Pickup Mtaani point near you.</span>
          </span>
        </label>
        <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-gold-light p-4 has-[:checked]:border-gold has-[:checked]:bg-blush">
          <input type="radio" name="delivery" value="Bolt rider" class="mt-0.5 accent-gold" />
          <span>
            <span class="block text-sm font-medium">Bolt rider</span>
            <span class="block text-sm text-taupe">A Bolt courier delivers to your address.</span>
          </span>
        </label>
        <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-gold-light p-4 has-[:checked]:border-gold has-[:checked]:bg-blush">
          <input type="radio" name="delivery" value="Contact for local arrangement" class="mt-0.5 accent-gold" />
          <span>
            <span class="block text-sm font-medium">Contact for local arrangement</span>
            <span class="block text-sm text-taupe">For destinations needing custom coordination &mdash; I'll arrange this with you directly.</span>
          </span>
        </label>
      </div>
      <div class="mt-6 flex gap-3">
        <button type="button" id="back-to-review" class="w-1/3 rounded-sm border border-gold-light px-6 py-3 text-sm font-semibold hover:bg-blush">
          Back
        </button>
        <button type="button" id="to-confirm" class="w-2/3 rounded-sm bg-gold px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-gold-dark">
          Continue to confirm
        </button>
      </div>
    </section>

    <!-- Step 3: Confirm -->
    <section id="step-confirm" class="mt-8 hidden">
      <p class="text-sm text-taupe">
        We'll open WhatsApp with your order details filled in &mdash; just hit send to reach me.
      </p>
      <ul id="confirm-lines" class="mt-4 divide-y divide-gold-light/40 rounded-lg border border-gold-light px-4"></ul>
      <div class="mt-4 space-y-2 rounded-lg bg-blush px-4 py-3">
        <p class="flex justify-between text-base font-semibold">
          <span>Total</span>
          <span id="confirm-total"></span>
        </p>
        <p class="flex justify-between text-sm text-taupe">
          <span>Delivery</span>
          <span id="confirm-delivery" class="font-medium text-ink"></span>
        </p>
      </div>
      <div class="mt-6 flex gap-3">
        <button type="button" id="back-to-delivery" class="w-1/3 rounded-sm border border-gold-light px-6 py-3 text-sm font-semibold hover:bg-blush">
          Back
        </button>
        <button type="button" id="send-order" class="w-2/3 rounded-sm bg-whatsapp px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#1da851]">
          Send order via WhatsApp
        </button>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  import { cartItems, updateQuantity, removeFromCart, cartTotalKes, clearCart, type CartItem } from "../lib/cart";
  import { formatKES } from "../lib/format";
  import { buildOrderWhatsAppUrl } from "../lib/whatsapp";
  import { showToast } from "../lib/toast";

  type Step = "review" | "delivery" | "confirm";
  const stepOrder: Step[] = ["review", "delivery", "confirm"];
  let step: Step = "review";
  let deliveryOption = "";

  const stepSections: Record<Step, HTMLElement | null> = {
    review: document.getElementById("step-review"),
    delivery: document.getElementById("step-delivery"),
    confirm: document.getElementById("step-confirm"),
  };
  const stepItems = document.querySelectorAll<HTMLElement>("[data-step-label]");
  const stepLines = document.querySelectorAll<HTMLElement>("[data-step-line]");
  const emptyEl = document.getElementById("cart-empty");

  function updateStepIndicator() {
    const currentIndex = stepOrder.indexOf(step);

    stepItems.forEach((item) => {
      const index = stepOrder.indexOf(item.dataset.stepLabel as Step);
      const circle = item.querySelector<HTMLElement>("[data-step-circle]");
      const isDone = index < currentIndex;
      const isActive = index === currentIndex;

      item.classList.toggle("text-ink", isActive);
      item.classList.toggle("text-taupe", !isActive);

      if (circle) {
        circle.classList.toggle("bg-gold", isActive || isDone);
        circle.classList.toggle("text-white", isActive || isDone);
        circle.classList.toggle("bg-blush", !isActive && !isDone);
        circle.classList.toggle("text-taupe", !isActive && !isDone);
        circle.classList.toggle("ring-2", isActive);
        circle.classList.toggle("ring-gold-light", isActive);
        circle.textContent = isDone ? "✓" : String(index + 1);
      }
    });

    stepLines.forEach((line, i) => {
      line.classList.toggle("bg-gold", i < currentIndex);
      line.classList.toggle("bg-gold-light", i >= currentIndex);
    });
  }

  function showStep(next: Step) {
    step = next;
    for (const key of Object.keys(stepSections) as Step[]) {
      stepSections[key]?.classList.toggle("hidden", key !== step);
    }
    updateStepIndicator();
  }

  function renderLines(container: HTMLElement, items: readonly CartItem[], withControls: boolean) {
    container.innerHTML = "";
    items.forEach((item, index) => {
      const li = document.createElement("li");
      li.className = "flex items-center justify-between gap-3 py-3 text-sm";

      const info = document.createElement("div");
      const sizePart = item.size ? `, Size: ${item.size}` : "";
      info.innerHTML = `<p class="font-medium">${item.name}</p><p class="text-ink/60">Colour: ${item.colour}${sizePart}</p>`;
      li.appendChild(info);

      const right = document.createElement("div");
      right.className = "flex items-center gap-3";

      if (withControls) {
        const qtyWrap = document.createElement("div");
        qtyWrap.className = "flex items-center gap-2";
        const dec = document.createElement("button");
        dec.type = "button";
        dec.textContent = "−";
        dec.className = "h-7 w-7 rounded-full border border-ink/15 text-sm";
        dec.addEventListener("click", () => updateQuantity(index, item.quantity - 1));
        const qty = document.createElement("span");
        qty.className = "w-5 text-center text-sm";
        qty.textContent = String(item.quantity);
        const inc = document.createElement("button");
        inc.type = "button";
        inc.textContent = "+";
        inc.className = "h-7 w-7 rounded-full border border-ink/15 text-sm";
        inc.addEventListener("click", () => updateQuantity(index, item.quantity + 1));
        qtyWrap.append(dec, qty, inc);
        right.appendChild(qtyWrap);

        const remove = document.createElement("button");
        remove.type = "button";
        remove.textContent = "Remove";
        remove.className = "text-xs text-ink/50 underline";
        remove.addEventListener("click", () => removeFromCart(index));
        right.appendChild(remove);
      } else {
        const qtyText = document.createElement("span");
        qtyText.className = "text-ink/60";
        qtyText.textContent = `Qty ${item.quantity}`;
        right.appendChild(qtyText);
      }

      const price = document.createElement("span");
      price.className = "font-medium";
      price.textContent = formatKES(item.priceKes * item.quantity);
      right.appendChild(price);

      li.appendChild(right);
      container.appendChild(li);
    });
  }

  function render(items: readonly CartItem[]) {
    emptyEl?.classList.toggle("hidden", items.length > 0);
    if (items.length === 0) {
      (["review", "delivery", "confirm"] as Step[]).forEach((s) => stepSections[s]?.classList.add("hidden"));
      updateStepIndicator();
      return;
    }
    if (stepSections[step] === undefined) return;

    const reviewLines = document.getElementById("cart-lines");
    const confirmLines = document.getElementById("confirm-lines");
    if (reviewLines) renderLines(reviewLines, items, true);
    if (confirmLines) renderLines(confirmLines, items, false);

    const total = formatKES(cartTotalKes(items));
    const totalEl = document.getElementById("cart-total");
    const confirmTotalEl = document.getElementById("confirm-total");
    if (totalEl) totalEl.textContent = total;
    if (confirmTotalEl) confirmTotalEl.textContent = total;

    showStep(step);
  }

  cartItems.subscribe(render);

  document.getElementById("to-delivery")?.addEventListener("click", () => showStep("delivery"));
  document.getElementById("back-to-review")?.addEventListener("click", () => showStep("review"));
  document.getElementById("back-to-delivery")?.addEventListener("click", () => showStep("delivery"));

  document.getElementById("to-confirm")?.addEventListener("click", () => {
    const selected = document.querySelector<HTMLInputElement>('input[name="delivery"]:checked');
    if (!selected) {
      showToast("Please select a delivery option", { variant: "error" });
      return;
    }
    deliveryOption = selected.value;
    const confirmDeliveryEl = document.getElementById("confirm-delivery");
    if (confirmDeliveryEl) confirmDeliveryEl.textContent = deliveryOption;
    showStep("confirm");
  });

  document.getElementById("send-order")?.addEventListener("click", () => {
    const items = cartItems.get();
    if (items.length === 0) return;
    const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? "";
    const url = buildOrderWhatsAppUrl(
      items.map((item) => ({
        name: item.name,
        colour: item.colour,
        size: item.size,
        quantity: item.quantity,
        priceKes: item.priceKes,
      })),
      whatsappNumber,
      deliveryOption,
    );
    window.open(url, "_blank", "noopener,noreferrer");
    clearCart();
  });
</script>
