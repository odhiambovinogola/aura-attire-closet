---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { supabase } from "../lib/supabase";
import { productImageUrl } from "../lib/images";
import { getSiteSettings } from "../lib/settings";
import type { Category, Product, ProductImage } from "../lib/types";

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
const greeting = encodeURIComponent("Hi Nash! I'd like to browse Aura Attire Closet.");
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${greeting}`;

const settings = await getSiteSettings();

let categories: Category[] = [];
let featured: Product[] = [];
let categoryImages: Record<string, ProductImage> = {};
let loadError: string | null = null;

try {
  const { data: categoryData, error: categoryError } = await supabase
    .from("categories")
    .select("*")
    .order("sort_order");
  if (categoryError) throw categoryError;
  categories = categoryData ?? [];

  const { data: featuredData, error: featuredError } = await supabase
    .from("products")
    .select("*, product_images(*)")
    .eq("is_published", true)
    .eq("is_featured", true)
    .order("sort_order")
    .limit(8);
  if (featuredError) throw featuredError;
  featured = featuredData ?? [];

  const { data: allProductsData, error: allProductsError } = await supabase
    .from("products")
    .select("category_id, product_images(*)")
    .eq("is_published", true)
    .order("sort_order");
  if (allProductsError) throw allProductsError;
  for (const product of allProductsData ?? []) {
    if (categoryImages[product.category_id]) continue;
    const image = product.product_images?.find((img: ProductImage) => img.is_primary) ?? product.product_images?.[0];
    if (image) categoryImages[product.category_id] = image;
  }
} catch (err) {
  loadError = err instanceof Error ? err.message : "Could not load the catalogue.";
}

const heroImagePath =
  settings.hero_image_path ??
  (featured.find((p) => p.product_images?.length)?.product_images?.find((img) => img.is_primary) ??
    featured.find((p) => p.product_images?.length)?.product_images?.[0])?.storage_path ??
  null;

// Home only highlights categories that actually have a photo yet — keeps the
// homepage from leading with "Coming soon" tiles. Everything is still browsable
// via /shop regardless; this just decides what gets front-row placement.
const photographedCategories = categories.filter((c) => categoryImages[c.id]).slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-cream px-4 pb-16 pt-12 sm:px-6 sm:pb-24 sm:pt-16">
    <div class="hero-grid mx-auto max-w-6xl gap-7 sm:gap-10">
      <div class="hero-head text-center sm:text-left">
        <p class="animate-fade-up text-xs font-semibold uppercase tracking-[0.2em] text-gold">
          Aura Attire Closet
        </p>
        <h1 class="animate-fade-up mt-4 font-[family-name:var(--font-display)] text-5xl font-bold leading-[1.05] text-ink sm:text-6xl">
          {settings.hero_tagline}
        </h1>
        <p class="animate-fade-up mt-5 max-w-md text-ink/70 sm:mx-0">
          {settings.hero_subcopy}
        </p>
      </div>

      <div class="hero-image animate-fade-up relative mx-auto aspect-[4/5] w-full max-w-sm rounded-2xl bg-blush/60 p-3 sm:max-w-none sm:bg-transparent sm:p-0">
        <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-gold-light/70 sm:-right-8 sm:-top-8 sm:h-56 sm:w-56"></div>
        {heroImagePath ? (
          <img
            src={productImageUrl(heroImagePath)}
            alt=""
            class="relative h-full w-full rounded-xl object-cover shadow-xl sm:rounded-sm"
          />
        ) : (
          <div class="relative flex h-full w-full items-center justify-center rounded-xl bg-blush text-sm text-taupe shadow-xl sm:rounded-sm">
            Aura Attire Closet
          </div>
        )}
        <div class="absolute -bottom-5 -left-5 h-16 w-16 rounded-full border-8 border-cream bg-ink sm:-bottom-6 sm:-left-6 sm:h-28 sm:w-28"></div>
      </div>

      <div class="hero-actions text-center sm:text-left">
        <div class="animate-fade-up flex flex-col gap-3 sm:flex-row sm:justify-start">
          <a
            href="/shop"
            class="inline-flex items-center justify-center gap-2 rounded-sm bg-gold px-7 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-gold-dark"
          >
            Browse the Shop
          </a>
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-sm border border-ink/15 px-7 py-3.5 text-sm font-semibold text-ink transition-colors hover:bg-blush"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
            Chat with Me
          </a>
        </div>

        <div class="animate-fade-up mt-6 flex items-center justify-center gap-3 sm:justify-start">
          <a
            href={settings.instagram_url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="flex h-9 w-9 items-center justify-center rounded-full border border-ink/15 text-ink/60 transition-colors hover:border-gold hover:text-gold"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38 3.7 3.7 0 0 1-1.38.9c-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.21 8.8 2.2 12 2.2zm0 1.8c-3.15 0-3.5.01-4.74.07-.96.04-1.48.2-1.82.34-.46.18-.78.39-1.12.73-.34.34-.55.66-.73 1.12-.13.34-.3.86-.34 1.82C3.21 8.5 3.2 8.85 3.2 12s.01 3.5.07 4.74c.04.96.21 1.48.34 1.82.18.46.39.78.73 1.12.34.34.66.55 1.12.73.34.13.86.3 1.82.34 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c.96-.04 1.48-.21 1.82-.34.46-.18.78-.39 1.12-.73.34-.34.55-.66.73-1.12.13-.34.3-.86.34-1.82.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.04-.96-.21-1.48-.34-1.82a2.97 2.97 0 0 0-.73-1.12 2.97 2.97 0 0 0-1.12-.73c-.34-.13-.86-.3-1.82-.34C15.5 4.01 15.15 4 12 4zm0 3.8a4.2 4.2 0 1 1 0 8.4 4.2 4.2 0 0 1 0-8.4zm0 1.8a2.4 2.4 0 1 0 0 4.8 2.4 2.4 0 0 0 0-4.8zm5.35-2.4a1 1 0 1 1-2 0 1 1 0 0 1 2 0z" /></svg>
          </a>
          <a
            href={settings.facebook_url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="flex h-9 w-9 items-center justify-center rounded-full border border-ink/15 text-ink/60 transition-colors hover:border-gold hover:text-gold"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M13.5 21v-7.5h2.5l.5-3h-3V8.2c0-.87.24-1.46 1.5-1.46H16.5V4.14C16.07 4.1 14.97 4 13.7 4 11.07 4 9.5 5.49 9.5 8v2.5H7v3h2.5V21h4z" /></svg>
          </a>
          <a
            href={settings.tiktok_url}
            aria-label="TikTok"
            class="flex h-9 w-9 items-center justify-center rounded-full border border-ink/15 text-ink/60 transition-colors hover:border-gold hover:text-gold"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M16.6 5.82s.51.5 0 0A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.592 2.592 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3s-1.88.09-3.24-1.48z"/></svg>
          </a>
          <span class="text-xs text-ink/50">{settings.instagram_followers}+ followers</span>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero-grid {
      display: grid;
      grid-template-areas: "head" "image" "actions";
      align-items: center;
    }
    @media (min-width: 640px) {
      .hero-grid {
        grid-template-columns: 1fr 1fr;
        grid-template-areas: "head image" "actions image";
        column-gap: 2.5rem;
      }
    }
    .hero-head {
      grid-area: head;
    }
    .hero-image {
      grid-area: image;
    }
    .hero-actions {
      grid-area: actions;
    }
  </style>

  {!loadError && photographedCategories.length > 0 && (
    <section class="bg-cream px-4 py-16 sm:px-6 sm:py-20">
      <div class="mx-auto max-w-6xl" data-reveal>
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold">Browse by Category</p>
            <h2 class="mt-2 font-[family-name:var(--font-display)] text-2xl font-bold sm:text-3xl">Shop the Collection</h2>
          </div>
          <a href="/shop" class="hidden shrink-0 text-sm font-medium text-gold hover:text-gold-dark sm:inline">View All &rarr;</a>
        </div>
        <div class="editorial-rule mt-6 mb-8"></div>

        <div class="grid grid-cols-2 gap-3 sm:gap-5 lg:grid-cols-4">
          {photographedCategories.map((category) => {
            const image = categoryImages[category.id];
            return (
              <a
                href={`/shop?category=${category.slug}`}
                class="group relative block aspect-[3/4] overflow-hidden rounded-sm bg-blush"
              >
                <img
                  src={productImageUrl(image.storage_path)}
                  alt={category.name}
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-transparent to-transparent"></div>
                <div class="absolute inset-x-0 bottom-0 p-4">
                  <h3 class="font-[family-name:var(--font-display)] text-base font-semibold leading-tight text-cream sm:text-lg">
                    {category.name}
                  </h3>
                  <span class="mt-1 flex items-center gap-1 text-xs text-gold-light opacity-0 transition-opacity group-hover:opacity-100">
                    Shop now &rarr;
                  </span>
                </div>
              </a>
            );
          })}

          <a
            href="/shop"
            class="group relative flex aspect-[3/4] flex-col items-center justify-center gap-2 overflow-hidden rounded-sm bg-ink text-cream"
          >
            <span class="font-[family-name:var(--font-display)] text-lg font-semibold sm:text-xl">Shop All</span>
            <span class="flex items-center gap-1 text-xs text-gold-light transition-transform group-hover:translate-x-1">
              Browse everything &rarr;
            </span>
          </a>
        </div>
      </div>
    </section>
  )}

  {!loadError && featured.length > 0 && (
    <section class="bg-blush px-4 py-16 sm:px-6 sm:py-20">
      <div class="mx-auto max-w-6xl" data-reveal>
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold">Hand-Picked for You</p>
            <h2 class="mt-2 font-[family-name:var(--font-display)] text-2xl font-bold sm:text-3xl">Featured Pieces</h2>
          </div>
          <a href="/shop" class="hidden shrink-0 text-sm font-medium text-gold hover:text-gold-dark sm:inline">View All &rarr;</a>
        </div>
        <div class="editorial-rule mt-6 mb-8"></div>

        <div class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 lg:grid-cols-4">
          {featured.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      </div>
    </section>
  )}

  {loadError && (
    <div class="mx-auto max-w-3xl px-4 py-12 text-center sm:px-6">
      <p class="rounded-lg bg-blush px-4 py-6 text-sm text-taupe">
        The catalogue isn't connected yet ({loadError}).
      </p>
    </div>
  )}

  <!-- Trust signals -->
  <section class="bg-ink px-4 py-16 sm:px-6 sm:py-20">
    <div class="mx-auto grid max-w-6xl gap-10 sm:grid-cols-3 sm:gap-8" data-reveal>
      {[
        {
          title: "Personally Curated",
          desc: "Every piece is picked and quality-checked by me before it reaches you.",
          path: "M9 12l2 2 4-4m5.5-2a9.5 9.5 0 1 1-19 0 9.5 9.5 0 0 1 19 0Z",
        },
        {
          title: "Flexible Delivery",
          desc: "Pickup Mtaani, Bolt rider, or a local arrangement — I work around you.",
          path: "M3 7h11v8H3V7Zm11 3h3l3 3v2h-6v-5ZM6.5 18a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm11 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z",
        },
        {
          title: "Personal Service",
          desc: "Order directly via WhatsApp — I'm always available to help you find the perfect fit.",
          path: "M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z",
        },
      ].map((item) => (
        <div class="flex flex-col items-center gap-4 text-center">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/5">
            <svg viewBox="0 0 24 24" class="h-7 w-7 stroke-gold" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.path} />
            </svg>
          </div>
          <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-cream">{item.title}</h3>
          <p class="text-sm leading-relaxed text-taupe">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Social -->
  <section class="bg-blush px-4 py-16 text-center sm:px-6 sm:py-20" data-reveal>
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold">Follow the Journey</p>
    <h2 class="mt-2 font-[family-name:var(--font-display)] text-2xl font-bold sm:text-3xl">@aura_attire_closet</h2>
    <p class="mt-3 text-sm text-taupe">Loved on Instagram by {settings.instagram_followers}+ followers</p>
    <div class="mt-6 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6">
      <a
        href="https://instagram.com/aura_attire_closet"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-sm border border-gold px-6 py-2.5 text-sm font-semibold text-gold transition-colors hover:bg-gold hover:text-white"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38 3.7 3.7 0 0 1-1.38.9c-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.21 8.8 2.2 12 2.2zm0 1.8c-3.15 0-3.5.01-4.74.07-.96.04-1.48.2-1.82.34-.46.18-.78.39-1.12.73-.34.34-.55.66-.73 1.12-.13.34-.3.86-.34 1.82C3.21 8.5 3.2 8.85 3.2 12s.01 3.5.07 4.74c.04.96.21 1.48.34 1.82.18.46.39.78.73 1.12.34.34.66.55 1.12.73.34.13.86.3 1.82.34 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c.96-.04 1.48-.21 1.82-.34.46-.18.78-.39 1.12-.73.34-.34.55-.66.73-1.12.13-.34.3-.86.34-1.82.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.04-.96-.21-1.48-.34-1.82a2.97 2.97 0 0 0-.73-1.12 2.97 2.97 0 0 0-1.12-.73c-.34-.13-.86-.3-1.82-.34C15.5 4.01 15.15 4 12 4zm0 3.8a4.2 4.2 0 1 1 0 8.4 4.2 4.2 0 0 1 0-8.4zm0 1.8a2.4 2.4 0 1 0 0 4.8 2.4 2.4 0 0 0 0-4.8zm5.35-2.4a1 1 0 1 1-2 0 1 1 0 0 1 2 0z" /></svg>
        Follow on Instagram
      </a>
      <a
        href="https://facebook.com/StyleWithnash"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-sm border border-gold px-6 py-2.5 text-sm font-semibold text-gold transition-colors hover:bg-gold hover:text-white"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M13.5 21v-7.5h2.5l.5-3h-3V8.2c0-.87.24-1.46 1.5-1.46H16.5V4.14C16.07 4.1 14.97 4 13.7 4 11.07 4 9.5 5.49 9.5 8v2.5H7v3h2.5V21h4z" /></svg>
        Follow on Facebook
      </a>
      <a
        href="#"
        class="inline-flex items-center gap-2 rounded-sm border border-gold px-6 py-2.5 text-sm font-semibold text-gold transition-colors hover:bg-gold hover:text-white"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M16.6 5.82s.51.5 0 0A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.592 2.592 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3s-1.88.09-3.24-1.48z"/></svg>
        Follow on TikTok
      </a>
    </div>
  </section>

  <!-- WhatsApp CTA -->
  <section class="relative overflow-hidden bg-gold px-4 py-16 text-center text-white sm:px-6 sm:py-20" data-reveal>
    <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold sm:text-4xl">
      Your next favourite outfit<br />is one message away.
    </h2>
    <p class="mx-auto mt-4 max-w-lg text-white/85">
      Browse the full collection, ask about sizing, or place your order directly on WhatsApp. I respond personally.
    </p>
    <a
      href={whatsappHref}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex items-center gap-2 rounded-sm bg-whatsapp px-8 py-4 text-sm font-bold text-white shadow-lg transition-colors hover:bg-[#1da851]"
    >
      Chat on WhatsApp
    </a>
  </section>
</BaseLayout>
