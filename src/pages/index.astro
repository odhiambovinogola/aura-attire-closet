---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <div class="mx-auto flex max-w-3xl flex-col items-center px-4 py-20 text-center sm:px-6">
    <h1 class="font-[family-name:var(--font-display)] text-3xl">Aura Attire Closet</h1>
    <p class="mt-3 text-ink/70">Elegant pieces for every closet &mdash; by Nash Mbula.</p>
    <a
      href="/shop"
      class="mt-8 rounded-full bg-ink px-6 py-3 text-sm font-semibold text-cream hover:opacity-90"
    >
      Browse the shop
    </a>
    <p class="mt-10 text-xs text-ink/40">
      This is an early build preview &mdash; the full home page is still being designed.
    </p>
  </div>
</BaseLayout>
