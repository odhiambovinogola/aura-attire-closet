---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { supabase } from "../../lib/supabase";
import { formatKES } from "../../lib/format";
import { colourToHex } from "../../lib/colours";
import { productImageUrl } from "../../lib/images";
import type { Product, Review } from "../../lib/types";

const { slug } = Astro.params;

let product: Product | null = null;
let reviews: Review[] = [];
let loadError: string | null = null;

try {
  const { data, error } = await supabase
    .from("products")
    .select("*, product_images(*)")
    .eq("slug", slug)
    .eq("is_published", true)
    .maybeSingle();
  if (error) throw error;
  product = data;

  if (product) {
    const { data: reviewData, error: reviewError } = await supabase
      .from("reviews")
      .select("*")
      .eq("product_id", product.id)
      .order("created_at", { ascending: false });
    if (reviewError) throw reviewError;
    reviews = reviewData ?? [];
  }
} catch (err) {
  loadError = err instanceof Error ? err.message : "Could not load this product.";
}

if (!product && !loadError) {
  return Astro.redirect("/shop");
}

const images = product?.product_images?.slice().sort((a, b) => a.sort_order - b.sort_order) ?? [];
const primaryImage = images.find((img) => img.is_primary) ?? images[0];
const averageRating = reviews.length
  ? (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(1)
  : null;
---

<BaseLayout title={product?.name ?? "Product"}>
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    {loadError && (
      <p class="rounded-lg bg-blush px-4 py-6 text-sm text-taupe">
        The catalogue isn't connected yet ({loadError}).
      </p>
    )}

    {product && (
      <nav class="mb-6 flex items-center gap-2 text-xs text-taupe">
        <a href="/" class="hover:text-gold">Home</a>
        <span>/</span>
        <a href="/shop" class="hover:text-gold">Shop</a>
        <span>/</span>
        <span class="text-ink">{product.name}</span>
      </nav>
    )}

    {product && (
      <div class="grid gap-8 sm:grid-cols-2">
        <div>
          <div class="aspect-[3/4] overflow-hidden rounded-sm bg-blush">
            {primaryImage ? (
              <img
                src={productImageUrl(primaryImage.storage_path)}
                alt={primaryImage.alt ?? product.name}
                class="h-full w-full object-cover"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center text-sm text-taupe">
                {product.name}
              </div>
            )}
          </div>
        </div>

        <div>
          <div class="flex items-start justify-between gap-3">
            <h1 class="font-[family-name:var(--font-display)] text-2xl font-bold">{product.name}</h1>
            <button
              type="button"
              id="wishlist-toggle"
              data-wishlist-slug={product.slug}
              data-wishlist-name={product.name}
              data-wishlist-price={product.price_kes}
              data-wishlist-image={primaryImage?.storage_path ?? ""}
              aria-label="Toggle wishlist"
              class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-gold-light hover:bg-blush"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                <path
                  d="M12 20s-7-4.35-9.5-8.5C.8 8.2 2.4 5 5.6 5c1.8 0 3.2.9 4 2.2C10.4 5.9 11.8 5 13.6 5 16.8 5 18.4 8.2 21.5 11.5 19 15.65 12 20 12 20z"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
          </div>
          <p class="mt-2 text-lg font-semibold text-gold">{formatKES(product.price_kes)}</p>

          {product.description ? (
            <p class="mt-4 text-sm text-ink/70">{product.description}</p>
          ) : (
            <p class="mt-4 text-sm italic text-taupe">Description coming soon.</p>
          )}

          {product.colours.length > 0 && (
            <div class="mt-6">
              <p class="text-sm font-medium">Colour</p>
              <div id="colour-chips" class="mt-2 flex flex-wrap gap-2">
                {product.colours.map((colour, i) => (
                  <button
                    type="button"
                    data-colour={colour}
                    aria-pressed={i === 0}
                    class="chip colour-chip flex items-center gap-2 rounded-full border border-gold-light px-3 py-1.5 text-sm transition-colors"
                  >
                    <span class="h-3.5 w-3.5 rounded-full border border-gold-light" style={`background-color: ${colourToHex(colour)}`} />
                    {colour}
                  </button>
                ))}
              </div>
            </div>
          )}

          {product.sizes.length > 0 ? (
            <div class="mt-6">
              <p class="text-sm font-medium">Size</p>
              <div id="size-chips" class="mt-2 flex flex-wrap gap-2">
                {product.sizes.map((size, i) => (
                  <button
                    type="button"
                    data-size={size}
                    aria-pressed={i === 0}
                    class="chip size-chip rounded-full border border-gold-light px-3.5 py-1.5 text-sm transition-colors"
                  >
                    {size}
                  </button>
                ))}
              </div>
            </div>
          ) : (
            <p class="mt-6 text-sm italic text-taupe">Sizes coming soon — free size unless noted.</p>
          )}

          <div class="mt-6">
            <p class="text-sm font-medium">Quantity</p>
            <div class="mt-2 flex items-center gap-3">
              <button type="button" id="qty-decrease" class="h-9 w-9 rounded-full border border-gold-light text-lg leading-none hover:bg-blush">&minus;</button>
              <span id="qty-value" class="w-6 text-center text-sm">1</span>
              <button type="button" id="qty-increase" class="h-9 w-9 rounded-full border border-gold-light text-lg leading-none hover:bg-blush">+</button>
            </div>
          </div>

          <button
            type="button"
            id="add-to-cart"
            data-product-slug={product.slug}
            data-product-name={product.name}
            data-price-kes={product.price_kes}
            class="mt-8 w-full rounded-sm bg-gold px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-gold-dark sm:sticky sm:bottom-4"
          >
            Add to Cart
          </button>
          <p id="add-to-cart-confirm" class="mt-3 hidden text-center text-sm text-taupe">
            Added to cart. <a href="/cart" class="font-medium text-gold underline">View cart &amp; order &rarr;</a>
          </p>
        </div>
      </div>
    )}

    {product && (
      <div class="mt-16 border-t border-gold-light/40 pt-10">
        <div class="flex items-baseline justify-between">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-bold">Reviews</h2>
          {averageRating && (
            <p class="text-sm text-taupe">{averageRating} &middot; {reviews.length} review{reviews.length === 1 ? "" : "s"}</p>
          )}
        </div>

        {reviews.length === 0 ? (
          <p class="mt-4 text-sm italic text-taupe">No reviews yet — be the first to leave one.</p>
        ) : (
          <ul class="mt-4 space-y-4">
            {reviews.map((review) => (
              <li class="rounded-lg bg-blush px-4 py-3">
                <div class="flex items-center justify-between text-sm">
                  <span class="font-medium">{review.author_name}</span>
                  <span class="text-gold">{"★".repeat(review.rating)}{"☆".repeat(5 - review.rating)}</span>
                </div>
                {review.body && <p class="mt-1 text-sm text-ink/70">{review.body}</p>}
              </li>
            ))}
          </ul>
        )}

        <form id="review-form" data-product-id={product.id} class="mt-8 max-w-md space-y-4">
          <h3 class="text-sm font-medium">Leave a review</h3>

          <div>
            <label for="review-name" class="block text-sm text-taupe">Your name</label>
            <input id="review-name" name="author_name" type="text" required maxlength="80"
              class="mt-1 w-full rounded-lg border border-gold-light px-3 py-2 text-sm" />
          </div>

          <div>
            <label for="review-rating" class="block text-sm text-taupe">Rating</label>
            <select id="review-rating" name="rating" required class="mt-1 w-full rounded-lg border border-gold-light px-3 py-2 text-sm">
              <option value="">Select a rating</option>
              <option value="5">5 — Excellent</option>
              <option value="4">4 — Good</option>
              <option value="3">3 — Okay</option>
              <option value="2">2 — Not great</option>
              <option value="1">1 — Poor</option>
            </select>
          </div>

          <div>
            <label for="review-body" class="block text-sm text-taupe">Review (optional)</label>
            <textarea id="review-body" name="body" maxlength="1000" rows="3"
              class="mt-1 w-full rounded-lg border border-gold-light px-3 py-2 text-sm"></textarea>
          </div>

          <input type="text" name="website" tabindex="-1" autocomplete="off"
            class="absolute h-0 w-0 opacity-0" aria-hidden="true" />

          <button type="submit" class="rounded-sm bg-gold px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gold-dark">
            Submit review
          </button>

          <p id="review-status" class="hidden text-sm"></p>
          <p class="text-xs text-taupe">Reviews are checked before they appear publicly.</p>
        </form>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  import { addToCart } from "../../lib/cart";
  import { wishlistItems, toggleWishlist, isWishlisted } from "../../lib/wishlist";

  const wishlistButton = document.getElementById("wishlist-toggle") as HTMLButtonElement | null;

  function syncWishlistButton() {
    if (!wishlistButton) return;
    const active = isWishlisted(wishlistButton.dataset.wishlistSlug ?? "");
    wishlistButton.classList.toggle("text-gold", active);
    wishlistButton.classList.toggle("border-gold", active);
    wishlistButton.querySelector("svg")?.setAttribute("fill", active ? "currentColor" : "none");
  }

  wishlistButton?.addEventListener("click", () => {
    toggleWishlist({
      productSlug: wishlistButton.dataset.wishlistSlug ?? "",
      name: wishlistButton.dataset.wishlistName ?? "",
      priceKes: Number(wishlistButton.dataset.wishlistPrice ?? 0),
      imagePath: wishlistButton.dataset.wishlistImage || undefined,
    });
  });

  syncWishlistButton();
  wishlistItems.subscribe(syncWishlistButton);

  const colourChipsEl = document.getElementById("colour-chips");
  const sizeChipsEl = document.getElementById("size-chips");
  const qtyValueEl = document.getElementById("qty-value");
  const addButton = document.getElementById("add-to-cart") as HTMLButtonElement | null;
  const confirmEl = document.getElementById("add-to-cart-confirm");

  let quantity = 1;

  function setActiveChip(container: HTMLElement, selected: HTMLElement) {
    container.querySelectorAll<HTMLElement>("button").forEach((btn) => {
      btn.setAttribute("aria-pressed", String(btn === selected));
    });
  }

  colourChipsEl?.addEventListener("click", (event) => {
    const target = (event.target as HTMLElement).closest<HTMLElement>(".colour-chip");
    if (target) setActiveChip(colourChipsEl, target);
  });

  sizeChipsEl?.addEventListener("click", (event) => {
    const target = (event.target as HTMLElement).closest<HTMLElement>(".size-chip");
    if (target) setActiveChip(sizeChipsEl, target);
  });

  document.getElementById("qty-decrease")?.addEventListener("click", () => {
    quantity = Math.max(1, quantity - 1);
    if (qtyValueEl) qtyValueEl.textContent = String(quantity);
  });

  document.getElementById("qty-increase")?.addEventListener("click", () => {
    quantity += 1;
    if (qtyValueEl) qtyValueEl.textContent = String(quantity);
  });

  addButton?.addEventListener("click", () => {
    const productSlug = addButton.dataset.productSlug ?? "";
    const name = addButton.dataset.productName ?? "";
    const priceKes = Number(addButton.dataset.priceKes ?? 0);
    const colour = colourChipsEl?.querySelector<HTMLElement>('[aria-pressed="true"]')?.dataset.colour ?? "Any";
    const size = sizeChipsEl?.querySelector<HTMLElement>('[aria-pressed="true"]')?.dataset.size;

    addToCart({ productSlug, name, colour, size, quantity, priceKes });
    confirmEl?.classList.remove("hidden");
  });

  const reviewForm = document.getElementById("review-form") as HTMLFormElement | null;
  const reviewStatus = document.getElementById("review-status");

  reviewForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const productId = reviewForm.dataset.productId ?? "";
    const formData = new FormData(reviewForm);

    const payload = {
      product_id: productId,
      author_name: String(formData.get("author_name") ?? ""),
      rating: Number(formData.get("rating")),
      body: String(formData.get("body") ?? ""),
      website: String(formData.get("website") ?? ""),
    };

    if (reviewStatus) {
      reviewStatus.textContent = "Submitting...";
      reviewStatus.classList.remove("hidden");
    }

    try {
      const response = await fetch("/api/reviews", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        const { error } = await response.json().catch(() => ({ error: "Something went wrong." }));
        if (reviewStatus) reviewStatus.textContent = error ?? "Something went wrong.";
        return;
      }

      reviewForm.reset();
      if (reviewStatus) reviewStatus.textContent = "Thanks! Your review will appear once it's checked.";
    } catch {
      if (reviewStatus) reviewStatus.textContent = "Could not reach the server. Please try again.";
    }
  });
</script>
