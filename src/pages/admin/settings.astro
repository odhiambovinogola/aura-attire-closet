---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin · Site Settings">
  <div class="mx-auto max-w-xl px-4 py-8 sm:px-6">
    <a href="/admin" class="text-sm text-ink/60 underline">&larr; Back to products</a>
    <h1 class="mt-3 font-[family-name:var(--font-display)] text-2xl">Site Settings</h1>
    <p class="mt-1 text-sm text-ink/50">Hero/About copy, photos, and social links shown across the site.</p>

    <div id="admin-loading" class="mt-10 text-sm text-ink/50">Checking session&hellip;</div>

    <form id="settings-form" class="mt-8 hidden space-y-6">
      <fieldset class="space-y-4">
        <legend class="text-sm font-semibold text-ink">Home hero</legend>
        <div>
          <label for="hero_tagline" class="block text-sm text-ink/70">Headline / tagline</label>
          <input id="hero_tagline" name="hero_tagline" type="text" required
            class="mt-1 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm" />
        </div>
        <div>
          <label for="hero_subcopy" class="block text-sm text-ink/70">Subtext</label>
          <textarea id="hero_subcopy" name="hero_subcopy" rows="3" required
            class="mt-1 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm"></textarea>
        </div>
        <div>
          <label for="hero_image" class="block text-sm text-ink/70">Hero photo</label>
          <p class="mt-1 text-xs text-ink/50">Leave unset to automatically use a featured product's photo.</p>
          <div id="hero-image-preview" class="mt-2 hidden">
            <img id="hero-image-preview-img" class="h-24 w-24 rounded-lg object-cover" alt="Current hero photo" />
          </div>
          <input id="hero_image" name="hero_image" type="file" accept="image/*"
            class="mt-2 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm" />
          <button type="button" id="hero-image-reset" class="mt-2 text-xs text-ink/50 underline">
            Use automatic photo instead
          </button>
        </div>
      </fieldset>

      <fieldset class="space-y-4 border-t border-ink/10 pt-6">
        <legend class="text-sm font-semibold text-ink">About page</legend>
        <div>
          <label for="about_body" class="block text-sm text-ink/70">About text (separate paragraphs with a blank line)</label>
          <textarea id="about_body" name="about_body" rows="8" required
            class="mt-1 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm"></textarea>
        </div>
        <div>
          <label for="about_image" class="block text-sm text-ink/70">About photo</label>
          <p class="mt-1 text-xs text-ink/50">Leave unset to automatically use a featured product's photo.</p>
          <div id="about-image-preview" class="mt-2 hidden">
            <img id="about-image-preview-img" class="h-24 w-24 rounded-lg object-cover" alt="Current about photo" />
          </div>
          <input id="about_image" name="about_image" type="file" accept="image/*"
            class="mt-2 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm" />
          <button type="button" id="about-image-reset" class="mt-2 text-xs text-ink/50 underline">
            Use automatic photo instead
          </button>
        </div>
      </fieldset>

      <fieldset class="space-y-4 border-t border-ink/10 pt-6">
        <legend class="text-sm font-semibold text-ink">Social links</legend>
        <div>
          <label for="instagram_url" class="block text-sm text-ink/70">Instagram URL</label>
          <input id="instagram_url" name="instagram_url" type="url" required
            class="mt-1 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm" />
        </div>
        <div>
          <label for="facebook_url" class="block text-sm text-ink/70">Facebook URL</label>
          <input id="facebook_url" name="facebook_url" type="url" required
            class="mt-1 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm" />
        </div>
        <div>
          <label for="tiktok_url" class="block text-sm text-ink/70">TikTok URL</label>
          <input id="tiktok_url" name="tiktok_url" type="text" required
            class="mt-1 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm" />
        </div>
      </fieldset>

      <fieldset class="space-y-4 border-t border-ink/10 pt-6">
        <legend class="text-sm font-semibold text-ink">Shop location</legend>
        <p class="text-xs text-ink/50">
          Only fill these in once you have a real public address you want customers to see — leave blank to keep the site delivery-only.
        </p>
        <div>
          <label for="shop_address" class="block text-sm text-ink/70">Address label (shown as text)</label>
          <input id="shop_address" name="shop_address" type="text" placeholder="e.g. Shop 12, ABC Plaza, Nairobi"
            class="mt-1 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm" />
        </div>
        <div>
          <label for="maps_url" class="block text-sm text-ink/70">Google Maps link</label>
          <input id="maps_url" name="maps_url" type="text" placeholder="https://maps.app.goo.gl/..."
            class="mt-1 w-full rounded-lg border border-ink/15 px-3 py-2 text-sm" />
        </div>
      </fieldset>

      <button type="submit" class="rounded-full bg-ink px-6 py-3 text-sm font-semibold text-cream hover:opacity-90">
        Save settings
      </button>
      <p id="form-status" class="hidden text-sm"></p>
    </form>
  </div>
</BaseLayout>

<script>
  import { supabase } from "../../lib/supabase";
  import { requireSession } from "../../lib/admin-auth";
  import { productImageUrl } from "../../lib/images";
  import { showToast } from "../../lib/toast";
  import imageCompression from "browser-image-compression";
  import type { SiteSettings } from "../../lib/types";

  const form = document.getElementById("settings-form") as HTMLFormElement;
  const formStatus = document.getElementById("form-status");

  let heroImagePath: string | null = null;
  let aboutImagePath: string | null = null;

  function fillForm(settings: SiteSettings) {
    (document.getElementById("hero_tagline") as HTMLInputElement).value = settings.hero_tagline;
    (document.getElementById("hero_subcopy") as HTMLTextAreaElement).value = settings.hero_subcopy;
    (document.getElementById("about_body") as HTMLTextAreaElement).value = settings.about_body;
    (document.getElementById("instagram_url") as HTMLInputElement).value = settings.instagram_url;
    (document.getElementById("facebook_url") as HTMLInputElement).value = settings.facebook_url;
    (document.getElementById("tiktok_url") as HTMLInputElement).value = settings.tiktok_url;
    (document.getElementById("shop_address") as HTMLInputElement).value = settings.shop_address ?? "";
    (document.getElementById("maps_url") as HTMLInputElement).value = settings.maps_url;

    heroImagePath = settings.hero_image_path;
    aboutImagePath = settings.about_image_path;
    syncImagePreview("hero", heroImagePath);
    syncImagePreview("about", aboutImagePath);
  }

  function syncImagePreview(prefix: "hero" | "about", path: string | null) {
    const wrapper = document.getElementById(`${prefix}-image-preview`);
    const img = document.getElementById(`${prefix}-image-preview-img`) as HTMLImageElement | null;
    if (!wrapper || !img) return;
    if (path) {
      img.src = productImageUrl(path);
      wrapper.classList.remove("hidden");
    } else {
      wrapper.classList.add("hidden");
    }
  }

  document.getElementById("hero-image-reset")?.addEventListener("click", () => {
    heroImagePath = null;
    syncImagePreview("hero", null);
    (document.getElementById("hero_image") as HTMLInputElement).value = "";
  });
  document.getElementById("about-image-reset")?.addEventListener("click", () => {
    aboutImagePath = null;
    syncImagePreview("about", null);
    (document.getElementById("about_image") as HTMLInputElement).value = "";
  });

  async function uploadIfChosen(inputId: string, slotName: "hero" | "about"): Promise<string | null | undefined> {
    const input = document.getElementById(inputId) as HTMLInputElement;
    const file = input.files?.[0];
    if (!file) return undefined; // no new file chosen — leave existing value alone

    const compressed = await imageCompression(file, { maxWidthOrHeight: 1600, maxSizeMB: 0.4, fileType: "image/webp" });
    const storagePath = `site/${slotName}-${Date.now()}.webp`;
    const { error } = await supabase.storage.from("product-images").upload(storagePath, compressed, { contentType: "image/webp" });
    if (error) {
      showToast(`Could not upload the ${slotName} photo`, { variant: "error", subtitle: error.message });
      return undefined;
    }
    return storagePath;
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();

    const uploadedHero = await uploadIfChosen("hero_image", "hero");
    const uploadedAbout = await uploadIfChosen("about_image", "about");

    const payload = {
      id: 1,
      hero_tagline: (document.getElementById("hero_tagline") as HTMLInputElement).value.trim(),
      hero_subcopy: (document.getElementById("hero_subcopy") as HTMLTextAreaElement).value.trim(),
      about_body: (document.getElementById("about_body") as HTMLTextAreaElement).value.trim(),
      instagram_url: (document.getElementById("instagram_url") as HTMLInputElement).value.trim(),
      facebook_url: (document.getElementById("facebook_url") as HTMLInputElement).value.trim(),
      tiktok_url: (document.getElementById("tiktok_url") as HTMLInputElement).value.trim(),
      shop_address: (document.getElementById("shop_address") as HTMLInputElement).value.trim() || null,
      maps_url: (document.getElementById("maps_url") as HTMLInputElement).value.trim() || "#",
      hero_image_path: uploadedHero !== undefined ? uploadedHero : heroImagePath,
      about_image_path: uploadedAbout !== undefined ? uploadedAbout : aboutImagePath,
    };

    const { error } = await supabase.from("site_settings").upsert(payload);

    if (error) {
      showToast("Could not save settings", { variant: "error", subtitle: error.message });
      if (formStatus) {
        formStatus.textContent = "Could not save: " + error.message;
        formStatus.classList.remove("hidden");
      }
      return;
    }

    showToast("Settings saved");
    if (formStatus) {
      formStatus.textContent = "Saved.";
      formStatus.classList.remove("hidden");
    }
    (document.getElementById("hero_image") as HTMLInputElement).value = "";
    (document.getElementById("about_image") as HTMLInputElement).value = "";
    heroImagePath = payload.hero_image_path;
    aboutImagePath = payload.about_image_path;
    syncImagePreview("hero", heroImagePath);
    syncImagePreview("about", aboutImagePath);
  });

  async function init() {
    const session = await requireSession();
    if (!session) return;

    const { data, error } = await supabase.from("site_settings").select("*").eq("id", 1).maybeSingle();
    document.getElementById("admin-loading")?.classList.add("hidden");

    if (error || !data) {
      const loading = document.getElementById("admin-loading");
      if (loading) {
        loading.textContent =
          "Could not load settings — the site_settings table may not exist yet. Run the new block in supabase/schema.sql first.";
        loading.classList.remove("hidden");
      }
      return;
    }

    fillForm(data as SiteSettings);
    form.classList.remove("hidden");
  }

  init();
</script>
