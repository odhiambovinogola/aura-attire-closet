---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin">
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h1 class="font-[family-name:var(--font-display)] text-2xl">Products</h1>
      <div class="flex flex-wrap gap-2 sm:gap-3">
        <a href="/admin/settings" class="rounded-full border border-ink/20 px-4 py-2 text-sm font-semibold hover:bg-ink/5">
          Site Settings
        </a>
        <a href="/admin/reviews" class="rounded-full border border-ink/20 px-4 py-2 text-sm font-semibold hover:bg-ink/5">
          Reviews
        </a>
        <a href="/admin/products/new" class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-cream hover:opacity-90">
          + New product
        </a>
        <button id="logout" type="button" class="rounded-full border border-ink/20 px-4 py-2 text-sm font-semibold hover:bg-ink/5">
          Log out
        </button>
      </div>
    </div>

    <div id="admin-loading" class="mt-10 text-sm text-ink/50">Checking session&hellip;</div>

    <section id="category-panel" class="mt-8 hidden rounded-lg border border-gold-light p-4">
      <p class="text-sm font-semibold">Categories</p>
      <ul id="category-rows" class="mt-3 space-y-2"></ul>
      <form id="category-add-form" class="mt-3 flex gap-2">
        <input
          id="new-category-name"
          type="text"
          placeholder="New category name"
          required
          class="flex-1 rounded-lg border border-ink/15 px-3 py-2 text-sm"
        />
        <button type="submit" class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-cream hover:opacity-90">
          Add
        </button>
      </form>
    </section>

    <input
      id="product-search"
      type="search"
      placeholder="Search products by name or category&hellip;"
      class="mt-6 hidden w-full max-w-sm rounded-lg border border-ink/15 px-3 py-2 text-sm"
    />

    <ul id="product-cards" class="mt-8 hidden flex-col gap-3 sm:hidden"></ul>

    <div class="mt-8 hidden overflow-x-auto max-sm:hidden" id="product-table-wrap">
      <table id="product-table" class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-ink/10 text-ink/50">
            <th class="py-2 pr-4 font-medium">Name</th>
            <th class="py-2 pr-4 font-medium">Category</th>
            <th class="py-2 pr-4 font-medium">Price</th>
            <th class="py-2 pr-4 font-medium">Published</th>
            <th class="py-2 pr-4 font-medium">Featured</th>
            <th class="py-2"></th>
          </tr>
        </thead>
        <tbody id="product-rows" class="divide-y divide-ink/10"></tbody>
      </table>
    </div>
  </div>
</BaseLayout>

<script>
  import { supabase } from "../../lib/supabase";
  import { requireSession, logout } from "../../lib/admin-auth";
  import { formatKES } from "../../lib/format";
  import { slugify } from "../../lib/format";
  import { showToast } from "../../lib/toast";
  import { confirmAction } from "../../lib/dialog";

  document.getElementById("logout")?.addEventListener("click", logout);

  let productCountByCategory = new Map<string, number>();

  async function loadCategoryPanel() {
    const { data: categories, error } = await supabase
      .from("categories")
      .select("id, name, slug")
      .order("sort_order");

    const rowsEl = document.getElementById("category-rows");
    if (error || !categories || !rowsEl) return;

    rowsEl.innerHTML = "";
    for (const category of categories) {
      const count = productCountByCategory.get(category.id) ?? 0;
      const li = document.createElement("li");
      li.className = "flex items-center gap-2";

      const input = document.createElement("input");
      input.type = "text";
      input.value = category.name;
      input.className = "flex-1 rounded-lg border border-ink/15 px-3 py-1.5 text-sm";

      input.addEventListener("change", async () => {
        const name = input.value.trim();
        if (!name || name === category.name) {
          input.value = category.name;
          return;
        }
        const { error: renameError } = await supabase
          .from("categories")
          .update({ name, slug: slugify(name) })
          .eq("id", category.id);
        if (renameError) {
          showToast("Could not rename category", { variant: "error", subtitle: renameError.message });
          input.value = category.name;
        } else {
          showToast("Category renamed");
          category.name = name;
          await loadProducts();
        }
      });

      const countEl = document.createElement("span");
      countEl.className = "w-20 shrink-0 text-right text-xs text-ink/50";
      countEl.textContent = `${count} item${count === 1 ? "" : "s"}`;

      const deleteBtn = document.createElement("button");
      deleteBtn.type = "button";
      deleteBtn.textContent = "Delete";
      deleteBtn.className = "shrink-0 text-xs text-ink/50 underline disabled:cursor-not-allowed disabled:opacity-40";
      deleteBtn.disabled = count > 0;
      deleteBtn.title = count > 0 ? "Move or delete its products first" : "";
      deleteBtn.addEventListener("click", async () => {
        const confirmed = await confirmAction({
          title: `Delete "${category.name}"?`,
          body: "This category has no products. This can't be undone.",
          confirmLabel: "Delete",
          danger: true,
        });
        if (!confirmed) return;

        const { error: deleteError } = await supabase.from("categories").delete().eq("id", category.id);
        if (deleteError) {
          showToast("Could not delete category", { variant: "error", subtitle: deleteError.message });
        } else {
          showToast("Category deleted");
          await loadCategoryPanel();
        }
      });

      li.append(input, countEl, deleteBtn);
      rowsEl.appendChild(li);
    }
  }

  document.getElementById("category-add-form")?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const input = document.getElementById("new-category-name") as HTMLInputElement;
    const name = input.value.trim();
    if (!name) return;

    const { error } = await supabase.from("categories").insert({ name, slug: slugify(name) });
    if (error) {
      showToast("Could not add category", { variant: "error", subtitle: error.message });
      return;
    }
    input.value = "";
    showToast("Category added");
    await loadCategoryPanel();
  });

  let allProducts: Array<Record<string, any>> = [];
  let categoryNameById = new Map<string, string>();

  function attachDeleteHandlers(container: Element) {
    container.querySelectorAll<HTMLButtonElement>("[data-delete-id]").forEach((button) => {
      button.addEventListener("click", async () => {
        const id = button.dataset.deleteId!;
        const name = button.dataset.deleteName ?? "this product";
        const confirmed = await confirmAction({
          title: `Delete "${name}"?`,
          body: "This removes the product and its photos. This can't be undone.",
          confirmLabel: "Delete",
          danger: true,
        });
        if (!confirmed) return;

        const { data: images } = await supabase.from("product_images").select("storage_path").eq("product_id", id);
        if (images && images.length > 0) {
          await supabase.storage.from("product-images").remove(images.map((img) => img.storage_path));
        }

        const { error: deleteError } = await supabase.from("products").delete().eq("id", id);
        if (deleteError) {
          showToast("Could not delete product", { variant: "error", subtitle: deleteError.message });
        } else {
          showToast("Product deleted");
          await loadProducts();
          await loadCategoryPanel();
        }
      });
    });
  }

  function renderRows(filter: string) {
    const rows = document.getElementById("product-rows");
    const cards = document.getElementById("product-cards");
    if (!rows || !cards) return;

    const needle = filter.trim().toLowerCase();
    const visible = needle
      ? allProducts.filter((product) => {
          const categoryName = categoryNameById.get(product.category_id) ?? "";
          return (
            product.name.toLowerCase().includes(needle) || categoryName.toLowerCase().includes(needle)
          );
        })
      : allProducts;

    rows.innerHTML = "";
    cards.innerHTML = "";

    for (const product of visible) {
      const categoryName = categoryNameById.get(product.category_id) ?? "";
      const price = formatKES(product.price_kes);

      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="py-3 pr-4 font-medium whitespace-nowrap">${product.name}</td>
        <td class="py-3 pr-4 text-ink/70 whitespace-nowrap">${categoryName}</td>
        <td class="py-3 pr-4 text-ink/70 whitespace-nowrap">${price}</td>
        <td class="py-3 pr-4 whitespace-nowrap">${product.is_published ? "Yes" : "No"}</td>
        <td class="py-3 pr-4 whitespace-nowrap">${product.is_featured ? "Yes" : "No"}</td>
        <td class="py-3 text-right whitespace-nowrap">
          <a href="/admin/products/${product.id}" class="font-medium underline">Edit</a>
          <button type="button" data-delete-id="${product.id}" data-delete-name="${product.name}" class="ml-3 text-ink/50 underline">Delete</button>
        </td>
      `;
      rows.appendChild(tr);

      const li = document.createElement("li");
      li.className = "rounded-lg border border-ink/10 p-4";
      li.innerHTML = `
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="font-medium">${product.name}</p>
            <p class="mt-0.5 text-xs text-ink/60">${categoryName} &middot; ${price}</p>
          </div>
          <span class="shrink-0 rounded-full px-2 py-0.5 text-xs ${
            product.is_published ? "bg-gold-light/40 text-ink" : "bg-ink/10 text-ink/50"
          }">${product.is_published ? "Published" : "Draft"}</span>
        </div>
        <div class="mt-3 flex items-center gap-4 text-sm">
          <a href="/admin/products/${product.id}" class="font-medium underline">Edit</a>
          <button type="button" data-delete-id="${product.id}" data-delete-name="${product.name}" class="text-ink/50 underline">Delete</button>
        </div>
      `;
      cards.appendChild(li);
    }

    if (visible.length === 0) {
      const tr = document.createElement("tr");
      tr.innerHTML = `<td class="py-6 text-center text-ink/50" colspan="6">No products match "${filter}".</td>`;
      rows.appendChild(tr);

      const li = document.createElement("li");
      li.className = "py-6 text-center text-sm text-ink/50";
      li.textContent = `No products match "${filter}".`;
      cards.appendChild(li);
    }

    attachDeleteHandlers(rows);
    attachDeleteHandlers(cards);
  }

  async function loadProducts() {
    const { data: categories } = await supabase.from("categories").select("id, name");
    categoryNameById = new Map((categories ?? []).map((c) => [c.id, c.name]));

    const { data: products, error } = await supabase
      .from("products")
      .select("*")
      .order("sort_order");

    document.getElementById("admin-loading")?.classList.add("hidden");

    if (error || !products) {
      const loading = document.getElementById("admin-loading");
      if (loading) {
        loading.textContent = "Could not load products.";
        loading.classList.remove("hidden");
      }
      return;
    }

    allProducts = products;

    productCountByCategory = new Map();
    for (const product of products) {
      productCountByCategory.set(product.category_id, (productCountByCategory.get(product.category_id) ?? 0) + 1);
    }

    document.getElementById("product-table-wrap")?.classList.remove("hidden");
    document.getElementById("product-cards")?.classList.remove("hidden");
    document.getElementById("product-cards")?.classList.add("flex");
    document.getElementById("product-search")?.classList.remove("hidden");
    document.getElementById("category-panel")?.classList.remove("hidden");

    renderRows((document.getElementById("product-search") as HTMLInputElement | null)?.value ?? "");
  }

  document.getElementById("product-search")?.addEventListener("input", (event) => {
    renderRows((event.target as HTMLInputElement).value);
  });

  async function init() {
    const session = await requireSession();
    if (!session) return;

    await loadProducts();
    await loadCategoryPanel();
  }

  init();
</script>
