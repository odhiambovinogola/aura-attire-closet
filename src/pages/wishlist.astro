---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Wishlist" description="Items you've saved for later at Aura Attire Closet.">
  <div class="mx-auto max-w-2xl px-4 py-8 sm:px-6">
    <div class="relative inline-block">
      <div class="absolute -left-4 -top-3 -z-10 h-12 w-12 rounded-full bg-gold-light/50"></div>
      <h1 class="font-[family-name:var(--font-display)] text-3xl font-bold text-ink">Your Wishlist</h1>
    </div>

    <div id="wishlist-empty" class="mt-10 hidden rounded-lg bg-blush px-4 py-10 text-center text-sm text-taupe">
      Nothing saved yet. <a href="/shop" class="font-medium text-gold underline">Browse the shop</a>.
    </div>

    <ul id="wishlist-lines" class="mt-8 divide-y divide-gold-light/40 rounded-lg border border-gold-light px-4"></ul>
  </div>
</BaseLayout>

<script>
  import { wishlistItems, removeFromWishlist, type WishlistItem } from "../lib/wishlist";
  import { addToCart } from "../lib/cart";
  import { formatKES } from "../lib/format";
  import { productImageUrl } from "../lib/images";
  import { showToast } from "../lib/toast";

  const emptyEl = document.getElementById("wishlist-empty");
  const linesEl = document.getElementById("wishlist-lines");

  function render(items: readonly WishlistItem[]) {
    emptyEl?.classList.toggle("hidden", items.length > 0);
    if (!linesEl) return;

    linesEl.innerHTML = "";
    for (const item of items) {
      const li = document.createElement("li");
      li.className = "flex items-center gap-3 py-3 text-sm";

      const thumb = document.createElement("div");
      thumb.className = "h-14 w-14 shrink-0 overflow-hidden rounded-lg bg-blush";
      if (item.imagePath) {
        const img = document.createElement("img");
        img.src = productImageUrl(item.imagePath);
        img.alt = item.name;
        img.className = "h-full w-full object-cover";
        thumb.appendChild(img);
      }

      const info = document.createElement("div");
      info.className = "flex-1";
      info.innerHTML = `<p class="font-medium">${item.name}</p><p class="text-ink/60">${formatKES(item.priceKes)}</p>`;

      const actions = document.createElement("div");
      actions.className = "flex items-center gap-3";

      const addButton = document.createElement("button");
      addButton.type = "button";
      addButton.textContent = "Add to Bag";
      addButton.className = "rounded-full bg-gold px-3 py-1.5 text-xs font-semibold text-white hover:bg-gold-dark";
      addButton.addEventListener("click", () => {
        addToCart({ productSlug: item.productSlug, name: item.name, colour: "Any", quantity: 1, priceKes: item.priceKes });
        showToast(`${item.name} added to your bag!`);
      });

      const removeButton = document.createElement("button");
      removeButton.type = "button";
      removeButton.textContent = "Remove";
      removeButton.className = "text-xs text-ink/50 underline";
      removeButton.addEventListener("click", () => removeFromWishlist(item.productSlug));

      actions.append(addButton, removeButton);
      li.append(thumb, info, actions);
      linesEl.appendChild(li);
    }
  }

  wishlistItems.subscribe(render);
</script>
