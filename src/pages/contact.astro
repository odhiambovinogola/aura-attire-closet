---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
const greeting = encodeURIComponent("Hi Nash! I have a question about Aura Attire Closet.");
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${greeting}`;
---

<BaseLayout title="Contact" description="Chat with Nash Mbula on WhatsApp, Instagram or Facebook.">
  <div class="mx-auto max-w-2xl px-4 py-16 text-center sm:px-6">
    <h1 class="font-[family-name:var(--font-display)] text-3xl">Get in touch</h1>
    <p class="mt-3 text-sm text-ink/70">
      WhatsApp is the fastest way to reach Nash &mdash; for questions, custom requests, or to
      complete an order.
    </p>

    <a
      href={whatsappHref}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex items-center gap-2 rounded-full bg-[#25D366] px-8 py-3 text-sm font-semibold text-white hover:opacity-90"
    >
      Chat on WhatsApp
    </a>

    <p class="mt-10 text-sm text-ink/70">
      Prefer Instagram or Facebook? Those work too &mdash; message whichever you're already on.
    </p>

    <div class="mt-4 flex justify-center gap-6 text-sm font-medium">
      <a
        href="https://instagram.com/aura_attire_closet"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gold"
      >
        Instagram
      </a>
      <a
        href="https://facebook.com/StyleWithnash"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gold"
      >
        Facebook
      </a>
    </div>
  </div>
</BaseLayout>
