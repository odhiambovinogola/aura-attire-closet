---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteSettings } from "../lib/settings";

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
const greeting = encodeURIComponent("Hi Nash! I have a question about Aura Attire Closet.");
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${greeting}`;
const settings = await getSiteSettings();
---

<BaseLayout title="Contact" description="Chat with Nash Mbula on WhatsApp, Instagram or Facebook.">
  <div class="mx-auto max-w-2xl px-4 py-16 text-center sm:px-6">
    <div class="relative inline-block">
      <div class="absolute -left-6 -top-4 -z-10 h-14 w-14 rounded-full bg-gold-light/50"></div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold">Aura Attire Closet</p>
      <h1 class="mt-2 font-[family-name:var(--font-display)] text-4xl font-bold text-ink">Get in Touch</h1>
    </div>
    <p class="mt-3 text-sm text-taupe">
      WhatsApp is the fastest way to reach me &mdash; for questions, custom requests, or to
      complete an order.
    </p>

    <a
      href={whatsappHref}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex items-center gap-2 rounded-sm bg-whatsapp px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#1da851]"
    >
      Chat on WhatsApp
    </a>

    <p class="mt-10 text-sm text-taupe">
      Prefer Instagram or Facebook? Those work too &mdash; message whichever you're already on.
    </p>

    <div class="mt-4 flex justify-center gap-6 text-sm font-medium">
      <a href={settings.instagram_url} target="_blank" rel="noopener noreferrer" class="text-gold hover:text-gold-dark">
        Instagram
      </a>
      <a href={settings.facebook_url} target="_blank" rel="noopener noreferrer" class="text-gold hover:text-gold-dark">
        Facebook
      </a>
      <a href={settings.tiktok_url} class="text-gold hover:text-gold-dark">TikTok</a>
    </div>

    {settings.shop_address && (
      <div class="mt-10 border-t border-gold-light/40 pt-8">
        <p class="text-sm text-taupe">Prefer to visit in person?</p>
        <p class="mt-1 text-sm font-medium text-ink">{settings.shop_address}</p>
        <a
          href={settings.maps_url}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-gold hover:text-gold-dark"
        >
          Get Directions on Google Maps &rarr;
        </a>
      </div>
    )}
  </div>
</BaseLayout>
