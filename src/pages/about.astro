---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout title="About" description="The story behind Aura Attire Closet — boutique fashion by Nash Mbula, since 2024.">
  <div class="mx-auto max-w-2xl px-4 py-16 sm:px-6">
    <h1 class="font-[family-name:var(--font-display)] text-3xl">About Aura Attire Closet</h1>

    <div class="mt-6 space-y-4 text-sm leading-relaxed text-ink/80">
      <p>
        Aura Attire Closet is a Nairobi-based closet of elegant dresses, two-piece sets,
        jumpsuits, bags and shoes, curated by Nash Mbula since 2024.
      </p>
      <p>
        Every piece is picked with one idea in mind: an endless wardrobe of outfits-of-the-day
        for the woman who wants to feel put together without overthinking it. Nash personally
        selects each item, and you can chat with her directly about sizing, styling, or anything
        else before you order.
      </p>
      <p>
        Aura Attire Closet started on WhatsApp and social media, and that personal,
        message-Nash-directly feel carries through here — browse the shop, pick your colour and
        size, and send your order straight to her.
      </p>
    </div>

    <div class="mt-10 flex gap-6 text-sm font-medium">
      <a
        href="https://instagram.com/aura_attire_closet"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gold"
      >
        Instagram &middot; 957 followers
      </a>
      <a
        href="https://facebook.com/StyleWithnash"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gold"
      >
        Facebook
      </a>
    </div>
  </div>
</BaseLayout>
